# No API keys here — keys are entered in the app's Settings panel
# and stored only in IndexedDB on the user's device.
#
# These non-secret defaults are the only values read at build time:
VITE_OPENAI_MODEL=gpt-4.1-mini
VITE_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
VITE_OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
VITE_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
